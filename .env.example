# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Application Settings ─────────────────────────
# Maximum upload file size in megabytes
MAX_FILE_SIZE_MB=5

# OpenAI model to use for corrections
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens per chunk sent to OpenAI (estimated as len(text)/4)
CHUNK_TOKEN_LIMIT=2000

# OpenAI generation temperature (lower = more deterministic)
OPENAI_TEMPERATURE=0.2
